# ==========================================
# DOCKER COMPOSE + BACKEND
# ==========================================

# Puerto del servidor API
PORT=4000

# Credenciales root de MongoDB
MONGO_INITDB_ROOT_USERNAME=mongo_user
MONGO_INITDB_ROOT_PASSWORD=mongo_pass_seguro_cambiame

# URI de conexión MongoDB (usa nombre del servicio 'mongo' de Docker Compose)
MONGO_URI=mongodb://mongo_user:mongo_pass_seguro_cambiame@mongo:27017/recipehub?authSource=admin

# Secreto JWT — cámbialo por algo largo y aleatorio en producción
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# URL del frontend para configurar CORS
FRONTEND_URL=https://app.recipehub.me

# Entorno de ejecución
NODE_ENV=production

# ==========================================
# CLOUDINARY (Subida de Imágenes)
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
